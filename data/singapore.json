    {
      "id": "registration-process",
      "title": "注册流程与步骤",
      "icon": "📝",
      "sections": [
        {
          "title": "注册步骤总览",
          "content": [
            {
              "type": "steps",
              "steps": [
                {
                  "step": 1,
                  "title": "公司名称申请",
                  "desc": "通过ACRA的BizFile+系统（bizfile.gov.sg）提交公司名称申请。名称须经ACRA预先批准，通常1小时内出结果。",
                  "duration": "1小时-1个工作日",
                  "fee": "15新元"
                },
                {
                  "step": 2,
                  "title": "准备注册信息",
                  "desc": "准备以下信息：(1) 公司名称及SSIC业务代码；(2) 注册地址；(3) 股东详情（姓名、住址、持股比例）；(4) 董事详情；(5) 公司秘书详情；(6) 注册资本金额。",
                  "duration": "1-2个工作日",
                  "fee": "免费（自行准备）"
                },
                {
                  "step": 3,
                  "title": "提交公司注册申请",
                  "desc": "通过BizFile+系统提交注册申请，填写公司章程细则（ Constitution）及公司详情。可使用Corppass账户或通过注册服务商代为提交。",
                  "duration": "即时至1个工作日",
                  "fee": "315新元（标准注册费）"
                },
                {
                  "step": 4,
                  "title": "领取注册证书",
                  "desc": "注册成功后在线获取：(1) 公司注册证书（Certificate of Incorporation）；(2) 商业登记证（Business Profile）；(3) 公司章程（Constitution）；(4) 唯一实体编号（UEN）。",
                  "duration": "即时",
                  "fee": "免费（含在注册费内）"
                },
                {
                  "step": 5,
                  "title": "后续事项",
                  "desc": "完成注册后需要：(1) 在60天内委任公司秘书；(2) 申请Corppass数字身份；(3) 向IRAS注册税务；(4) 开设银行账户；(5) 如注册GST（年营业额超100万新元强制注册）。",
                  "duration": "1-4周",
                  "fee": "视服务而定"
                }
              ]
            }
          ],
          "lastVerified": "2026-06-01",
          "sources": [
            {
              "name": "ACRA BizFile+",
              "url": "https://www.bizfile.gov.sg/",
              "type": "official"
            },
            {
              "name": "GoBusiness - 创业指南",
              "url": "https://www.gobusiness.gov.sg/resources/start-up-guide/",
              "type": "official"
            }
