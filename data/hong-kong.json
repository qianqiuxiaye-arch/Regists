          "content": [
            {
              "type": "table",
              "headers": ["要求项", "具体要求"],
              "rows": [
                ["股东", "至少1名股东，无国籍/居住地限制；可为个人或公司法人"],
                ["董事", "至少1名自然人董事；无国籍限制；内地居民可担任"],
                ["公司秘书", "必须委任；须为香港居民或持牌公司服务提供商；可由董事兼任"],
                ["注册地址", "须提供香港本地地址（不可使用邮政信箱）；秘书公司一般可提供"],
                ["注册资本", "无最低限额；通常设定1万港币；无须验资"],
                ["公司名称", "须以「有限公司」结尾；不可与已注册公司重名；不需要包含「香港」"],
                ["经营范围", "可填写业务性质（英文描述），无严格限制"]
