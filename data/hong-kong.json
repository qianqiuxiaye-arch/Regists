    {
      "id": "registration-process",
      "title": "注册流程与步骤",
      "icon": "📝",
      "sections": [
        {
          "title": "注册步骤总览",
          "content": [
            {
              "type": "steps",
              "steps": [
                {
                  "step": 1,
                  "title": "公司名称查册",
                  "desc": "在香港公司注册处的网上查册中心（eCRIS）查询拟用公司名称是否可用。名称须唯一且符合《公司条例》规定。",
                  "duration": "即时",
                  "fee": "免费"
                },
                {
                  "step": 2,
                  "title": "准备注册文件",
                  "desc": "准备以下文件：(1) 公司章程细则（Articles of Association）；(2) 法团成立表格（NNC1）- 含公司名称、注册地址、股东/董事/秘书资料、注册资本等信息。",
                  "duration": "1-3个工作日",
                  "fee": "视秘书服务而定"
                },
                {
                  "step": 3,
                  "title": "提交注册申请",
                  "desc": "可通过以下方式提交：(1) 电子提交：通过「注册易」（e-Registry）在线提交NNC1表格；(2) 纸质提交：到公司注册处柜台递交。电子提交有10%费用折扣。",
                  "duration": "1小时（电子）/ 即时",
                  "fee": "电子：1,530港币；纸质：1,700港币"
                },
                {
                  "step": 4,
                  "title": "领取公司注册证书",
                  "desc": "注册完成后领取：(1) 公司注册证书（Certificate of Incorporation）；(2) 商业登记证（Business Registration Certificate）- 由税务局商业登记署同步签发。",
                  "duration": "电子提交约1小时内；纸质提交约4个工作日",
                  "fee": "商业登记证：2,150港币（一年期）/ 5,200港币（三年期）"
                },
                {
                  "step": 5,
                  "title": "后续事项",
                  "desc": "完成注册后需要：(1) 刻制公司印章；(2) 准备法定记录册（股东名册、董事名册等）；(3) 开设银行账户；(4) 如有需要，向内地商务部门做ODI备案。",
                  "duration": "1-2周",
                  "fee": "视服务而定"
                }
              ]
            }
          ],
          "lastVerified": "2026-06-01",
          "sources": [
            {
              "name": "香港公司注册处 - 注册流程",
