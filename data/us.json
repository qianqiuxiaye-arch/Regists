    {
      "id": "registration-process",
      "title": "注册流程与步骤",
      "icon": "📝",
      "sections": [
        {
          "title": "注册步骤总览（以LLC为例）",
          "content": [
            {
              "type": "steps",
              "steps": [
                {
                  "step": 1,
                  "title": "选择注册州",
                  "desc": "根据业务需求选择注册州。常见选择：(1) 特拉华州 - 最完善的公司法体系；(2) 怀俄明州 - 成本低且隐私保护好；(3) 实际经营州 - 如业务在特定州经营，建议在该州注册。",
                  "duration": "1-3天",
                  "fee": "免费（自行研究）"
                },
                {
                  "step": 2,
                  "title": "选择注册代理人",
                  "desc": "每个州要求公司有一个注册代理人（Registered Agent），负责接收法律文书。可使用专业注册代理人服务商（如Northwest Registered Agent, LegalZoom等）。",
                  "duration": "即时",
                  "fee": "$50-300/年"
                },
                {
                  "step": 3,
                  "title": "提交组织章程 (Articles of Organization)",
                  "desc": "在该州州务卿网站提交组织章程（各州名称可能不同），包含公司名称、地址、注册代理人信息、成员信息等。",
                  "duration": "即时-5个工作日",
                  "fee": "特拉华$90；怀俄明$100；新墨西哥$50；各州不同"
                },
                {
                  "step": 4,
                  "title": "申请EIN (雇主识别号)",
                  "desc": "向IRS申请EIN（Employer Identification Number），用于税务申报、银行开户、雇员管理等。外国人可通过IRS在线申请（须有ITIN或SSN）或邮寄SS-4表格。",
                  "duration": "在线即时",
                  "fee": "免费"
                },
                {
                  "step": 5,
                  "title": "申请ITIN（如适用）",
                  "desc": "如没有SSN，须向IRS申请个人纳税人识别号（ITIN）用于税务申报。须提交W-7表格并附护照原件或经认证副本。",
                  "duration": "7-11周",
                  "fee": "免费"
                },
                {
                  "step": 6,
                  "title": "BOI受益人信息申报",
                  "desc": "根据《企业透明度法案》(CTA)，2024年起所有新注册公司须在90天内向FinCEN申报受益所有人信息（BOI），包括姓名、出生日期、地址、身份证件等。注意：该法案目前已受到法律挑战，请关注最新进展。",
                  "duration": "1-2小时（在线填写）",
                  "fee": "免费"
                },
                {
                  "step": 7,
                  "title": "后续事项",
                  "desc": "完成注册后需要：(1) 签署运营协议；(2) 开设商业银行账户；(3) 各州年费/特许税缴纳安排；(4) 如有经营，申请地方营业执照；(5) 开通银行账户。",
                  "duration": "1-4周",
                  "fee": "视服务而定"
                }
              ]
            }
          ],
          "lastVerified": "2026-06-01",
          "sources": [
            {
              "name": "IRS - EIN申请",
              "url": "https://www.irs.gov/businesses/small-businesses-self-employed/apply-for-an-employer-identification-number-ein-online",
              "type": "official"
            },
